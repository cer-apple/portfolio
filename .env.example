# Copy to .env for local development. Never commit .env itself.

# Required in production. Locally, omit to fall back to the dev key in settings.py.
SECRET_KEY=replace-with-a-long-random-string

# True for local dev; production must be False.
DEBUG=True

# Comma-separated. Production already includes .onrender.com via the default.
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional. Without this, the project uses local SQLite (db.sqlite3).
# Render injects this automatically from the Postgres add-on.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional. Comma-separated origins allowed to POST forms (CSRF).
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
